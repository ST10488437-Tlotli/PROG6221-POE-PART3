<Window x:Class="CyberGuardianSA_Part3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberGuardian SA" Height="600" Width="800"
        WindowStartupLocation="CenterScreen" Background="#2D2D30">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Simple Header -->
        <Border Grid.Row="0" Background="#3D3D40" Padding="10" Margin="0,0,0,5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔒 CyberGuardian SA" FontSize="20" FontWeight="Bold" Foreground="#00FFFF"/>
                <TextBlock Text="| Part 3" FontSize="14" Foreground="#888" Margin="10,0,0,0"/>
                <Button Content="📋 Show Log" Click="ShowLogButton_Click" Margin="20,0,0,0" 
                        Background="#007ACC" Foreground="White" BorderThickness="0" Padding="8,3"/>
            </StackPanel>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Background="#2D2D30" BorderThickness="0">

            <!-- TAB 1: Chat -->
            <TabItem Header="💬 Chat" Background="#2D2D30" Foreground="White">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <RichTextBox Grid.Row="0" Name="chatDisplay" Background="#1E1E1E" Foreground="White" 
                                 IsReadOnly="True" BorderBrush="#3D3D40" BorderThickness="1" Margin="0,0,0,5"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBox Name="inputTextBox" Background="White" Foreground="Black" Height="30" 
                                 VerticalContentAlignment="Center" Width="500" Margin="0,0,5,0"/>
                        <Button Name="sendButton" Content="Send" Width="70" Height="30" 
                                Background="#007ACC" Foreground="White" BorderThickness="0" Click="SendButton_Click"/>
                        <Button Name="voiceToggleButton" Content="🔊 Voice" Width="70" Height="30" Margin="5,0,0,0" 
                                Background="#555" Foreground="White" BorderThickness="0" Click="VoiceToggleButton_Click"/>
                    </StackPanel>
                    <WrapPanel Grid.Row="2" Margin="0,5,0,0">
                        <Button Content="➕ Add Task" Click="QuickReply_Click" Background="#6A3A8A" Foreground="White" Margin="0,0,5,0" Padding="8,3"/>
                        <Button Content="🎮 Quiz" Click="QuickReply_Click" Background="#3A8A8A" Foreground="White" Margin="0,0,5,0" Padding="8,3"/>
                        <Button Content="📋 Log" Click="QuickReply_Click" Background="#8A6A3A" Foreground="White" Margin="0,0,5,0" Padding="8,3"/>
                        <Button Content="🔐 Password" Click="QuickReply_Click" Background="#3A5F8A" Foreground="White" Margin="0,0,5,0" Padding="8,3"/>
                        <Button Content="🎣 Phishing" Click="QuickReply_Click" Background="#8A3A3A" Foreground="White" Margin="0,0,5,0" Padding="8,3"/>
                    </WrapPanel>
                </Grid>
            </TabItem>

            <!-- TAB 2: Tasks (with DataTrigger) -->
            <TabItem Header="✅ Tasks" Background="#2D2D30" Foreground="White">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Your Cybersecurity Tasks (MySQL)" FontSize="14" FontWeight="Bold" 
                               Foreground="#00FFFF" Margin="0,0,0,10"/>

                    <!-- ListBox with DataTrigger -->
                    <ListBox Grid.Row="1" Name="taskListBox" Background="#1E1E1E" Foreground="White" 
                             BorderBrush="#3D3D40" BorderThickness="1" Margin="0,0,0,10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox/>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="White"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                        <Setter Property="Foreground" Value="Gray"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <TextBox Name="taskTitleBox" Background="White" Foreground="Black" Height="25" Width="120" 
                                 VerticalContentAlignment="Center" Margin="0,0,5,0" ToolTip="Title"/>
                        <TextBox Name="taskDescBox" Background="White" Foreground="Black" Height="25" Width="200" 
                                 VerticalContentAlignment="Center" Margin="0,0,5,0" ToolTip="Description"/>
                        <DatePicker Name="taskReminderPicker" Height="25" Width="100" Margin="0,0,5,0"/>
                        <Button Name="addTaskButton" Content="Add" Width="60" Height="25" 
                                Background="#007ACC" Foreground="White" BorderThickness="0" Click="AddTaskButton_Click"/>
                        <Button Name="deleteTaskButton" Content="Delete" Width="60" Height="25" Margin="5,0,0,0" 
                                Background="#CC3333" Foreground="White" BorderThickness="0" Click="DeleteTaskButton_Click"/>
                        <Button Name="refreshTasksButton" Content="⟳" Width="40" Height="25" Margin="5,0,0,0" 
                                Background="#555" Foreground="White" BorderThickness="0" Click="RefreshTasksButton_Click" FontSize="16"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- TAB 3: Quiz -->
            <TabItem Header="🎮 Quiz" Background="#2D2D30" Foreground="White">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Cybersecurity Quiz" FontSize="16" FontWeight="Bold" Foreground="#00FFFF"/>
                        <TextBlock Name="scoreDisplay" Text="Score: 0/0" FontSize="14" Foreground="#FFD700" Margin="20,0,0,0"/>
                        <Button Name="resetQuizButton" Content="Reset" Width="70" Height="25" Margin="20,0,0,0" 
                                Background="#555" Foreground="White" BorderThickness="0" Click="ResetQuizButton_Click"/>
                    </StackPanel>
                    <TextBlock Grid.Row="1" Name="questionDisplay" Text="Click 'Start Quiz' to begin!" 
                               FontSize="14" Foreground="White" TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <StackPanel Grid.Row="2" Name="answersPanel" Margin="0,0,0,10"/>
                    <Button Grid.Row="3" Name="startQuizButton" Content="🚀 Start Quiz" Width="120" Height="30" 
                            HorizontalAlignment="Center" Background="#007ACC" Foreground="White" BorderThickness="0" Click="StartQuizButton_Click"/>
                </Grid>
            </TabItem>

            <!-- TAB 4: Activity Log -->
            <TabItem Header="📋 Log" Background="#2D2D30" Foreground="White">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Activity Log" FontSize="16" FontWeight="Bold" Foreground="#00FFFF"/>
                        <Button Name="clearLogButton" Content="Clear" Width="60" Height="25" Margin="20,0,0,0" 
                                Background="#CC3333" Foreground="White" BorderThickness="0" Click="ClearLogButton_Click"/>
                        <Button Name="exportLogButton" Content="Export" Width="60" Height="25" Margin="10,0,0,0" 
                                Background="#007ACC" Foreground="White" BorderThickness="0" Click="ExportLogButton_Click"/>
                    </StackPanel>
                    <ListBox Grid.Row="1" Name="logListBox" Background="#1E1E1E" Foreground="#AAA" 
                             BorderBrush="#3D3D40" BorderThickness="1" FontSize="11" FontFamily="Consolas"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>